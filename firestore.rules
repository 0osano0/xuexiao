rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // WARNING: LOCAL AUTH SYSTEM ENABLED
    // ===============================================================
    // This project has been configured to use a custom local authentication
    // system instead of Firebase Auth. As a result, Firestore Security Rules
    // cannot verify the user's identity server-side.
    // Access control is managed primarily through the application logic.
    // ===============================================================

    match /articles/{articleId} {
      // Allow public read for published articles
      allow read: if resource.data.isPublished == true || true;
      
      // Allow write for all (managed by app logic)
      allow write: if true;
    }

    match /users/{userId} {
      // Allow access for all (managed by app logic)
      allow read, write: if true;
    }
  }
}
