rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: articles
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - content: string (required, 1-50000 chars)
    //   - summary: string (optional, 0-500 chars)
    //   - coverImage: string (optional, URL)
    //   - author: string (optional, 0-50 chars)
    //   - category: string (optional, enum)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //   - isPublished: bool (required)
    //
    // Collection: users
    // Document ID: Firebase Auth UID
    // Fields:
    //   - username: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, enum: admin, editor)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == "admin" || 
         (request.auth.token.email == "uldgxk@gmail.com" && request.auth.token.email_verified == true));
    }

    function isEditor() {
      return isAuthenticated() && 
        (getUserData().role == "editor" || isAdmin());
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt', 'updatedAt', 'isPublished']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 50000 &&
             data.isPublished is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'role', 'createdAt']) &&
             data.username is string && data.username.size() > 0 &&
             data.role in ['admin', 'editor'] &&
             data.createdAt is timestamp;
    }

    match /articles/{articleId} {
      // 所有人可以读取已发布的文章
      allow read: if resource.data.isPublished == true || isEditor();
      
      // 管理员和编辑可以写入
      allow create: if isEditor() && isValidArticle(request.resource.data);
      allow update: if isEditor() && isValidArticle(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // 只有管理员可以管理用户
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isAdmin() && isValidUser(request.resource.data);
    }
  }
}
